# =============================================================================
# LeadScout v2 — environment configuration (copy to .env, never commit .env)
# Everything works offline with NO keys set (heuristic extractor fallback).
# Add keys to unlock LLM-quality research/diagnosis.
# =============================================================================

# --- Identity (used in polite User-Agent + compliance footers) ---------------
OPERATOR_EMAIL=you@example.com
OPERATOR_NAME=Your Name
POSTAL_ADDRESS="123 Example St, City, Country"   # required by CAN-SPAM footer

# --- LLM providers (all optional; router degrades gracefully) -----------------
# Routing (SPEC §4.1): OpenAI frontier (signal extraction, diagnosis, demo generation,
#   proposal/architecture reasoning; budget-capped) with Groq -> Gemini as the free
#   budget/error fallback. Groq/Gemini also handle light bulk polish (outreach/content) for free.
GROQ_API_KEY=                        # bulk extraction (free tier)
GEMINI_API_KEY=                      # bulk fallback (free tier)
OPENAI_API_KEY=                      # frontier reasoning (default provider)
ANTHROPIC_API_KEY=                   # optional — only used if FRONTIER_PROVIDER=anthropic

# Frontier provider for premium reasoning (only called for the ~30-50 curated accounts).
FRONTIER_PROVIDER=openai             # openai (default) | anthropic  (provider-agnostic router)
FRONTIER_MODEL=gpt-5-mini            # lightweight GPT-5 reasoning; gpt-5 for max quality, gpt-5-nano for cheapest

# --- Enrichment / verification utilities (optional) --------------------------
GITHUB_TOKEN=
GITHUB_ENRICHMENT=true               # attach GitHub eng-context facts to briefs (official API; set false to skip)
HUNTER_API_KEY=

# --- Budget guards (hard caps; warn at 80%) ----------------------------------
FRONTIER_MONTHLY_BUDGET_INR=1000     # ₹1,000/mo frontier cap (SPEC §4.5)
GROQ_DAILY_REQUEST_CAP=14000         # stay under Groq free 14,400/day
HUNTER_MONTHLY_CAP=50

# --- Crawl politeness (SPEC §4.1) --------------------------------------------
CRAWL_MIN_INTERVAL_SECONDS=2.0       # per-domain minimum gap
CRAWL_TIMEOUT_SECONDS=10
CRAWL_MAX_PAGES_PER_COMPANY=8
USE_BROWSER_FALLBACK=false           # B7: render JS-only pages (needs: pip install -e ".[browser]" && playwright install chromium)

# --- Paths (defaults are fine) -----------------------------------------------
DATABASE_URL=sqlite:///data/leadscout.sqlite
DATA_DIR=data
KERNEL_PATH=kernel/niche.yaml
